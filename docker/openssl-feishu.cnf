#
# OpenSSL configuration for Hermes + Feishu compatibility
# Forces TLS 1.2 to avoid handshake timeout with OpenSSL 3.5.5
#

openssl_conf = default_conf

[default_conf]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
MinProtocol = TLSv1.2
MaxProtocol = TLSv1.2
CipherString = DEFAULT@SECLEVEL=2
