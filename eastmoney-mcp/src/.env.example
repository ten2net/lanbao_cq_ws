# 东方财富 API 配置
# 从东方财富网页版登录后，从浏览器开发者工具中获取
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 保护不会被提交

# AppKey（用于自选股管理）
EASTMONEY_APPKEY=your_appkey_here

# Cookie（用于获取自选股列表）
# 格式: ct=xxx; ut=xxx;
EASTMONEY_COOKIE=your_cookie_here

# 用户ID（备用方式获取自选股）
EASTMONEY_USER_ID=your_user_id_here

# 预警配置（可选）
ALERT_CHANGE_PCT=5.0
ALERT_VOLUME_SURGE=2.0
ALERT_INTERVAL=5
